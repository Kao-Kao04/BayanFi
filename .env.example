# Application
NODE_ENV=development
APP_NAME=BayanFi
APP_URL=http://localhost:3000
API_URL=http://localhost:4000
AI_SERVICE_URL=http://localhost:8000

# Database (PostgreSQL) — RECOMMENDED: Supabase (hosted, free, no local install)
#
# Supabase setup:
#   1. Create a project at https://supabase.com
#   2. Project Settings -> Database -> Connection string -> URI
#   3. Use the DIRECT connection (host db.<ref>.supabase.co, port 5432 -- "Session mode").
#      Prisma migrations need session mode, NOT the transaction pooler (port 6543).
#   4. Replace [YOUR-PASSWORD] with your database password.
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.<ref>.supabase.co:5432/postgres?sslmode=require"
#
# Local Docker alternative:
#   DATABASE_URL="postgresql://postgres:postgres@localhost:5432/bayanfi?schema=public"

# Redis — OPTIONAL. Not required for the MVP (rate limiting is in-memory).
# Only set these if you enable Phase 2 queues/caching.
REDIS_HOST=
REDIS_PORT=
REDIS_PASSWORD=

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-this-in-production
JWT_REFRESH_EXPIRES_IN=7d

# Stellar Network (testnet for development)
STELLAR_NETWORK=testnet
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# Stellar Accounts (Generate these using stellar-setup script)
STELLAR_MASTER_PUBLIC_KEY=
STELLAR_MASTER_SECRET_KEY=

# Soroban
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
SOROBAN_NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# AI Services
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4-turbo-preview
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Ollama (for local AI)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama2

# File Storage
STORAGE_TYPE=local
STORAGE_LOCAL_PATH=./uploads
MAX_FILE_SIZE=10485760

# AWS S3 (if using cloud storage)
AWS_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=

# Email (SendGrid)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@bayanfi.io
SENDGRID_FROM_NAME=BayanFi

# SMS (Twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Security
BCRYPT_ROUNDS=10
RATE_LIMIT_WINDOW=15m
RATE_LIMIT_MAX_REQUESTS=100

# Encryption
ENCRYPTION_KEY=your-32-character-encryption-key-here

# Audit
AUDIT_LOG_RETENTION_DAYS=2555

# Feature Flags
ENABLE_DISASTER_MODE=true
ENABLE_AI_FEATURES=true
ENABLE_MERCHANT_SYSTEM=true

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_APP_NAME=BayanFi
NEXT_PUBLIC_STELLAR_NETWORK=testnet
NEXT_PUBLIC_ENABLE_ANALYTICS=false

# Analytics (optional)
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_MIXPANEL_TOKEN=

# Sentry (optional)
SENTRY_DSN=
SENTRY_ENVIRONMENT=development

# Logging
LOG_LEVEL=info
LOG_FORMAT=json
